generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// NextAuth Models
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application Models
enum ProjectType {
  BROKER
  RENOVATION
  REAL_ESTATE
}

enum ProjectStatus {
  ONGOING
  COMPLETED
}

model Project {
  id          String        @id @default(cuid())
  title       String
  description String        @db.Text
  type        ProjectType
  status      ProjectStatus?
  price       String?
  location    String?
  features    String?       @db.Text
  images      String        @db.Text
  youtubeUrl  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Career {
  id           String   @id @default(cuid())
  title        String
  description  String   @db.Text
  requirements String   @db.Text
  emailTo      String
  images       String?  @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CsrActivity {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  images      String   @db.Text
  youtubeUrl  String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LandSubmission {
  id              String   @id @default(cuid())
  ownerName       String
  phone           String
  email           String
  mapsLink        String?
  landArea        String
  legality        String
  cooperationType String   @db.Text
  meetingDate     String?
  photos          String?  @db.Text
  createdAt       DateTime @default(now())
}

model InvestmentSubmission {
  id               String   @id @default(cuid())
  ownerName        String
  phone            String
  email            String
  projectInterest  String
  capitalRange     String
  cooperationTypes String   @db.Text
  meetingDate      String?
  createdAt        DateTime @default(now())
}
